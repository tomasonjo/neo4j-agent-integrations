# Neo4j Connection (Company News Knowledge Graph — demo access)
NEO4J_URI=neo4j+s://demo.neo4jlabs.com:7687
NEO4J_USERNAME=companies
NEO4J_PASSWORD=companies
NEO4J_DATABASE=companies

# Bridge Server Auth (set a strong random key)
API_KEY=your-secret-api-key-here

# Embeddings (for vector search)
OPENAI_API_KEY=sk-...

# Salesforce AgentForce (for agentforce_agent.py)
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_CLIENT_ID=your-connected-app-consumer-key
SF_CLIENT_SECRET=your-connected-app-consumer-secret
SF_AGENT_ID=0Xxxx000000xxxxx

# Server config
PORT=8080
